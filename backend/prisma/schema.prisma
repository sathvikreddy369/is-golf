generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum PlanType {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
}

enum PaymentStatus {
  CREATED
  SUCCESS
  FAILED
}

enum DrawMode {
  RANDOM
  WEIGHTED
}

enum DrawStatus {
  SIMULATED
  PUBLISHED
}

enum WinnerTier {
  MATCH_3
  MATCH_4
  MATCH_5
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PENDING
  PAID
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  password        String
  fullName        String
  role            Role           @default(USER)
  isActive        Boolean        @default(true)
  emailNotifications Boolean      @default(true)
  charityId       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  charity         Charity?       @relation(fields: [charityId], references: [id])
  subscription    Subscription?
  scores          Score[]
  winners         Winner[]
  payments        Payment[]

  @@index([email])
}

model Subscription {
  id                String             @id @default(cuid())
  userId            String             @unique
  planType          PlanType
  price             Decimal            @db.Decimal(10, 2)
  status            SubscriptionStatus @default(ACTIVE)
  renewalDate       DateTime
  charityPercentage Decimal            @db.Decimal(5, 2)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id])
}

model Score {
  id        String   @id @default(cuid())
  userId    String
  value     Int
  date      DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Draw {
  id            String      @id @default(cuid())
  mode          DrawMode
  status        DrawStatus
  winningValues Int[]
  poolAmount    Decimal     @db.Decimal(12, 2)
  drawDate      DateTime    @default(now())
  createdAt     DateTime    @default(now())
  results       DrawResult[]

  @@index([drawDate])
}

model DrawResult {
  id         String     @id @default(cuid())
  drawId     String
  tier       WinnerTier
  winnerIds  String[]
  totalPrize Decimal    @db.Decimal(12, 2)
  perWinner  Decimal    @db.Decimal(12, 2)
  createdAt  DateTime   @default(now())
  draw       Draw       @relation(fields: [drawId], references: [id])

  @@index([drawId, tier])
}

model Charity {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String?
  description String
  image       String
  website     String
  featured    Boolean  @default(false)
  location    String?
  upcomingEventTitle String?
  upcomingEventDate  DateTime?
  impactMetric String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model Winner {
  id                 String             @id @default(cuid())
  userId             String
  drawId             String
  tier               WinnerTier
  amount             Decimal            @db.Decimal(12, 2)
  proofImage         String?
  verificationStatus VerificationStatus @default(PENDING)
  payoutStatus       PayoutStatus       @default(PENDING)
  createdAt          DateTime           @default(now())
  user               User               @relation(fields: [userId], references: [id])

  @@index([userId, drawId])
}

model Payment {
  id                    String        @id @default(cuid())
  userId                String
  subscriptionAmount    Decimal       @db.Decimal(10, 2)
  charityContribution   Decimal       @db.Decimal(10, 2)
  poolContribution      Decimal       @db.Decimal(10, 2)
  razorpayOrderId       String
  razorpayPaymentId     String?
  razorpaySignature     String?
  status                PaymentStatus @default(CREATED)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}
